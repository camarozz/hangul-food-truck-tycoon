{
  "entities": {
    "UserProgress": {
      "title": "User Progress",
      "description": "Stores the player's game state and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "money": { "type": "number", "description": "Current funds in KRW." },
        "reputation": { "type": "number", "description": "Current reputation points." },
        "day": { "type": "number", "description": "Current game day." },
        "gas": { "type": "number", "description": "Current fuel percentage." },
        "dishesMastered": { "type": "number", "description": "Number of dishes mastered." },
        "permits": { "type": "array", "items": { "type": "string" }, "description": "List of location IDs the player has permits for." },
        "unlockedUpgrades": { "type": "array", "items": { "type": "string" }, "description": "List of upgrade IDs the player has purchased." },
        "inventory": {
          "type": "object",
          "properties": {
            "items": { "type": "object", "description": "Map of item IDs to quantities." },
            "maxStorage": { "type": "number", "description": "Maximum storage capacity." }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Timestamp of the last save." }
      },
      "required": ["uid", "money", "reputation", "day", "gas", "dishesMastered"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProgress",
      "description": "Collection of user progress documents."
    }
  }
}
