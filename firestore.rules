rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The user's unique ID.
    //   - money: number (required) - Current funds in KRW.
    //   - reputation: number (required) - Current reputation points.
    //   - day: number (required) - Current game day.
    //   - gas: number (required) - Current fuel percentage.
    //   - dishesMastered: number (required) - Number of dishes mastered.
    //   - lastUpdated: string (optional) - Timestamp of the last save.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['uid', 'money', 'reputation', 'day', 'gas', 'dishesMastered']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.money is number && data.money >= 0 &&
             data.reputation is number && data.reputation >= 0 &&
             data.day is number && data.day >= 0 &&
             data.gas is number && data.gas >= 0 && data.gas <= 100 &&
             data.dishesMastered is number && data.dishesMastered >= 0 &&
             (!('permits' in data) || data.permits is list) &&
             (!('unlockedUpgrades' in data) || data.unlockedUpgrades is list) &&
             (!('inventory' in data) || (data.inventory is map));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProgress(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProgress(request.resource.data);
      allow delete: if false; // Progress should not be deleted by users
    }
  }
}
